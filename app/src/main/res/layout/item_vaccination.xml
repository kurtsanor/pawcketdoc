<?xml version="1.0" encoding="utf-8"?>
<com.chauthai.swipereveallayout.SwipeRevealLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRevealLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="3dp"
    app:dragEdge="left"
    app:mode="same_level">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:layout_marginVertical="4dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_swipe_delete"
            android:contentDescription="Delete vaccination"
            android:padding="18dp"
            android:src="@drawable/ic_delete_24"
            app:tint="@color/white" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/frontCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="1dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/border"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/vaccinationIcon"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginEnd="15dp"
                android:src="@drawable/secure"
                android:padding="8dp"
                app:tint="@color/accent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/vaccinationName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Anti-Rabies"
                    android:fontFamily="@font/inter_semibold"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <View
                    android:layout_width="wrap_content"
                    android:layout_height="1dp"
                    android:layout_marginVertical="6dp"
                    android:background="@color/surface_muted" />

                <TextView
                    android:id="@+id/vaccinationNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Vaccine for Buddy"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="@color/text_secondary"
                    android:ellipsize="end"
                    android:maxLines="1" />

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_tint"
                android:layout_marginStart="10dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SHOT"
                        android:textSize="10sp"
                        android:fontFamily="@font/inter_bold"
                        android:textColor="@color/accent" />

                    <TextView
                        android:id="@+id/vaccinationDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter_bold"
                        android:text="12 JAN"
                        android:textSize="12sp"
                        android:textColor="@color/accent" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</com.chauthai.swipereveallayout.SwipeRevealLayout>
