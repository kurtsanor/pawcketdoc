<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/placeholder_empty_growth"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:layout_marginTop="10dp"
    android:layout_marginBottom="10dp"
    >

    <ImageView
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:src="@drawable/growth_placeholder"
        android:contentDescription="No growths" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No growth entries yet"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:fontFamily="@font/inter_bold"
        android:layout_marginTop="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add your pet's first record"
        android:textSize="13sp"
        android:textColor="@color/subtle_gray"
        android:fontFamily="@font/inter_regular"
        android:layout_marginTop="4dp" />

</LinearLayout>