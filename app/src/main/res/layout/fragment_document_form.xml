<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@color/white"
        android:padding="16dp">

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="#E0E0E0"
            app:boxStrokeWidth="1.5dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:boxBackgroundColor="@android:color/white"
            app:hintTextColor="@color/accent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDocumentName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Document Name"
                android:inputType="textCapWords"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular"
                android:background="@drawable/rounded_edit_text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Document Type Dropdown -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="#E0E0E0"
            app:boxStrokeWidth="1.5dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:boxBackgroundColor="@android:color/white"
            app:hintTextColor="@color/accent">

            <AutoCompleteTextView
                android:id="@+id/actvDocumentType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Document Type"
                android:inputType="none"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular"
                android:background="@drawable/rounded_edit_text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Date Issued -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="#E0E0E0"
            app:boxStrokeWidth="1.5dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:boxBackgroundColor="@android:color/white"
            app:hintTextColor="@color/accent"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            app:startIconTint="@color/accent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDateIssued"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="false"
                android:hint="Date Issued"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular"
                android:background="@drawable/rounded_edit_text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- File Upload -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="#E0E0E0"
            app:boxStrokeWidth="1.5dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:boxBackgroundColor="@android:color/white"
            app:hintTextColor="@color/accent"
            app:startIconTint="@color/accent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="false"
                android:hint="Attach File (PDF, JPG, PNG)"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular"
                android:background="@drawable/rounded_edit_text"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Notes -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusBottomEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusTopStart="12dp"
            app:boxStrokeColor="#E0E0E0"
            app:boxStrokeWidth="1.5dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:boxBackgroundColor="@android:color/white"
            app:hintTextColor="@color/accent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Notes (Optional)"
                android:inputType="textMultiLine"
                android:lines="3"
                android:gravity="top"
                android:textSize="14sp"
                android:fontFamily="@font/inter_regular"
                android:background="@drawable/rounded_edit_text"/>
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/buttonAddDocument"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/button_3d"
                app:backgroundTint="@null"
                android:fontFamily="@font/inter_bold"
                android:text="Add Document"
                android:textColor="@color/white" />

            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/white"
                android:visibility="gone" />

        </FrameLayout>

    </LinearLayout>

</LinearLayout>