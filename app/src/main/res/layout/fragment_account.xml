<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_primary"
    tools:context=".ui.AccountFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:orientation="vertical"
        android:background="@color/bg_secondary">

        <!-- Profile Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="1dp"
            app:cardMaxElevation="3dp"
            android:layout_marginHorizontal="3dp"
            android:layout_marginBottom="15dp"
            app:cardCornerRadius="15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="24dp"
                android:paddingHorizontal="5dp"
                android:gravity="center">

                <!-- Avatar with camera button -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:id="@+id/userAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/placeholder_profile"
                        android:clipToOutline="true"
                        android:background="@drawable/circle_border"
                        android:scaleType="centerCrop" />

                    <!-- Upload overlay -->
                    <FrameLayout
                        android:id="@+id/uploadOverlay"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center"
                        android:clipToOutline="true"
                        android:outlineProvider="bounds"
                        android:visibility="gone">
                        <ProgressBar
                            android:id="@+id/uploadProgress"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:indeterminateTint="@color/accent" />
                    </FrameLayout>

                    <!-- Camera button -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnChangePhoto"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        android:backgroundTint="@color/bg_secondary">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/camera"
                            app:tint="@color/text_primary" />
                    </androidx.cardview.widget.CardView>

                </FrameLayout>

                <TextView
                    android:id="@+id/fullName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_bold"
                    android:text="John Doe"
                    android:textAlignment="center"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pet Owner"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp"
                    android:textAlignment="center"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Account Settings Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="15dp"
            android:layout_marginBottom="15dp"
            app:cardElevation="1dp"
            app:cardMaxElevation="3dp"
            app:cardPreventCornerOverlap="true"
            android:layout_marginHorizontal="3dp"
            app:contentPadding="15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Account Settings"
                    android:layout_marginBottom="15dp"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvEditProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Edit Profile"
                    android:textSize="16sp"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="@color/text_primary"
                    android:drawableLeft="@drawable/edit"
                    android:drawableRight="@drawable/rightarrow"
                    android:drawablePadding="20dp"
                    android:drawableTint="@color/text_primary"
                    android:minHeight="48dp"
                    android:gravity="center_vertical"/>

                <TextView
                    android:id="@+id/tvChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Change Password"
                    android:textSize="16sp"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="@color/text_primary"
                    android:drawableLeft="@drawable/reset"
                    android:drawableRight="@drawable/rightarrow"
                    android:drawablePadding="12dp"
                    android:drawableTint="@color/text_primary"
                    android:minHeight="48dp"
                    android:gravity="center_vertical"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Preferences Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="15dp"
            android:layout_marginBottom="15dp"
            app:cardElevation="1dp"
            app:cardMaxElevation="3dp"
            app:cardPreventCornerOverlap="true"
            android:layout_marginHorizontal="3dp"
            app:contentPadding="15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Preferences"
                    android:layout_marginBottom="15dp"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="@color/text_secondary" />

                <!-- Dark Mode Toggle Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:minHeight="48dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/darkmode"
                        android:layout_marginEnd="20dp"
                        app:tint="@color/text_primary"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Dark Mode"
                        android:textSize="16sp"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="@color/text_primary"/>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        app:thumbTint="@color/accent"
                        app:trackTint="@color/text_secondary"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Log Out button -->
        <Button
            android:id="@+id/logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/button_3d_logout"
            app:backgroundTint="@null"
            app:icon="@drawable/logout"
            app:iconGravity="textStart"
            android:fontFamily="@font/inter_bold"
            android:text="Log Out"
            android:textColor="@color/white" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>