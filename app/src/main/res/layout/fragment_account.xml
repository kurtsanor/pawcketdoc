<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/secondary"
    tools:context=".ui.AccountFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:orientation="vertical">

        <!-- Profile Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="1dp"
            app:cardMaxElevation="3dp"
            android:layout_marginHorizontal="3dp"
            android:layout_marginBottom="15dp"
            app:cardCornerRadius="15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="24dp"
                android:paddingHorizontal="5dp"
                android:gravity="center">

                <!-- Avatar with camera button -->
                <FrameLayout
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:id="@+id/userAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/placeholder_profile"
                        android:clipToOutline="true"
                        android:background="@drawable/circle_border"
                        android:scaleType="centerCrop" />

                    <!-- Upload overlay -->
                    <FrameLayout
                        android:id="@+id/uploadOverlay"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_gravity="center"
                        android:clipToOutline="true"
                        android:outlineProvider="bounds"
                        android:visibility="gone">
                        <ProgressBar
                            android:id="@+id/uploadProgress"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="center"
                            android:indeterminateTint="@color/accent" />
                    </FrameLayout>

                    <!-- Camera button -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnChangePhoto"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp"
                        android:backgroundTint="@color/secondary">
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:layout_gravity="center"
                            android:src="@drawable/camera"
                            app:tint="@color/black" />
                    </androidx.cardview.widget.CardView>

                </FrameLayout>

                <!-- MD3 Title Large: 22sp bold — bumped from 20sp, profile name is a prominent identity element -->
                <TextView
                    android:id="@+id/fullName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter_bold"
                    android:text="John Doe"
                    android:textAlignment="center"
                    android:textColor="@color/black"
                    android:textSize="18sp" />

                <!-- MD3 Body Medium: 14sp regular — reduced from 16sp; role label is supporting text -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pet Owner"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="#7E7E7E"
                    android:layout_marginTop="2dp"
                    android:textAlignment="center"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Account Settings Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="15dp"
            android:layout_marginBottom="15dp"
            app:cardElevation="1dp"
            app:cardMaxElevation="3dp"
            app:cardPreventCornerOverlap="true"
            android:layout_marginHorizontal="3dp"
            app:contentPadding="15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- MD3 Label Small: 12sp regular — reduced from 14sp semibold; section labels are secondary chrome -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Account Settings"
                    android:layout_marginBottom="15dp"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="#767676" />

                <!-- MD3 Body Large: 16sp regular — weight reduced from semibold (600) to regular (400) -->
                <TextView
                    android:id="@+id/tvEditProfile"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Edit Profile"
                    android:textSize="16sp"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="@color/black"
                    android:drawableLeft="@drawable/edit"
                    android:drawableRight="@drawable/rightarrow"
                    android:drawablePadding="20dp"
                    android:minHeight="48dp"
                    android:gravity="center_vertical"/>

                <!-- MD3 Body Large: 16sp regular — weight reduced from semibold (600) to regular (400) -->
                <TextView
                    android:id="@+id/tvChangePassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Change Password"
                    android:textSize="16sp"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="@color/black"
                    android:drawableLeft="@drawable/reset"
                    android:drawableRight="@drawable/rightarrow"
                    android:drawablePadding="12dp"
                    android:minHeight="48dp"
                    android:gravity="center_vertical"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Log Out button — font unchanged, already correct -->
        <Button
            android:id="@+id/logout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/button_3d_logout"
            app:backgroundTint="@null"
            app:icon="@drawable/logout"
            app:iconGravity="textStart"
            android:fontFamily="@font/inter_bold"
            android:text="Log Out"
            android:textColor="@color/white" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>