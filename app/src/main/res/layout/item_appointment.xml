<?xml version="1.0" encoding="utf-8"?>
<com.chauthai.swipereveallayout.SwipeRevealLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRevealLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="3dp"
    app:dragEdge="left"
    app:mode="same_level">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="72dp"
            android:layout_height="match_parent"
            android:layout_marginVertical="4dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_swipe_delete"
            android:contentDescription="Delete appointment"
            android:padding="18dp"
            android:src="@drawable/ic_delete_24"
            app:tint="@color/white" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/frontCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="1dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/border"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/appointmentIcon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center_vertical"
                android:layout_marginEnd="15dp"
                android:src="@drawable/clock"
                app:tint="@color/accent"
                android:padding="10dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/appointmentTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Annual Checkup"
                    android:textSize="16sp"
                    android:fontFamily="@font/inter_semibold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/appointmentDateTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Jan 15, 2026 • 10:30 AM"
                    android:textSize="14sp"
                    android:fontFamily="@font/inter_regular"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/appointmentStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirmed"
                    android:textSize="12sp"
                    android:fontFamily="@font/inter_bold"
                    android:textColor="@color/accent"
                    android:layout_marginTop="6dp"
                    android:background="@color/surface_tint"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp" />

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</com.chauthai.swipereveallayout.SwipeRevealLayout>
